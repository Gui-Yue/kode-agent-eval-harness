{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UnifiedRunReport",
  "type": "object",
  "required": [
    "run_id",
    "benchmark",
    "dataset",
    "agent",
    "model",
    "commit_sha",
    "seed",
    "timeout_ms",
    "started_at",
    "finished_at",
    "tasks",
    "summary"
  ],
  "properties": {
    "run_id": { "type": "string" },
    "benchmark": { "type": "string" },
    "dataset": { "type": "string" },
    "agent": { "type": "string" },
    "model": { "type": "string" },
    "commit_sha": { "type": "string" },
    "seed": { "type": "number" },
    "timeout_ms": { "type": "number", "minimum": 1 },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["task_id", "passed", "score", "duration_ms"],
        "properties": {
          "task_id": { "type": "string" },
          "passed": { "type": "boolean" },
          "score": { "type": "number" },
          "duration_ms": { "type": "number", "minimum": 0 },
          "error_code": { "type": "string" },
          "token_usage": {
            "type": ["object", "null"],
            "properties": {
              "input_tokens": { "type": ["number", "null"], "minimum": 0 },
              "output_tokens": { "type": ["number", "null"], "minimum": 0 },
              "cache_tokens": { "type": ["number", "null"], "minimum": 0 },
              "total_tokens": { "type": ["number", "null"], "minimum": 0 },
              "latency_ms": { "type": ["number", "null"], "minimum": 0 }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "object",
      "required": ["pass_rate", "avg_latency_ms", "error_distribution"],
      "properties": {
        "pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "avg_latency_ms": { "type": "number", "minimum": 0 },
        "error_distribution": {
          "type": "object",
          "additionalProperties": { "type": "number", "minimum": 0 }
        },
        "avg_tokens": { "type": ["number", "null"], "minimum": 0 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
