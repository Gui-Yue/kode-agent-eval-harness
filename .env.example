# ===== Real provider credentials =====
# Pick the provider you use in --model=<provider>/<model>

# Global benchmark defaults used when CLI flags are omitted
BENCHMARK_PROVIDER=openai
BENCHMARK_MODEL=glm-5

# OpenAI-compatible providers (OpenAI / GLM / other compatible endpoints)
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL_ID=

# Gemini
GEMINI_API_KEY=
GEMINI_BASE_URL=
GEMINI_MODEL_ID=

# ===== Benchmark helper vars (optional) =====
# Used by tb2/tau helpers when needed
BENCHMARK_DOCKER_PROXY=
